
//-------------------------------------------------------//
// Object collision overrides for Player 3               //
//-------------------------------------------------------//
// The base game's platform functions (fn01dc56, etc.)
// check P1 then P2. They save/restore D1-D4 before the
// P1 check, but P2 is the last check so its register
// corruption doesn't matter — unless we add P3.
//
// Strategy: save D1-D4 BEFORE calling base, let base
// handle P1/P2 (corrupting registers), then restore
// D1-D4 and run the P3 check with correct parameters.
//
// P3 tracks platform riding via char.object_standing_on
// (offset 0x42), matching the game's own mechanism.
// We can't use the object's flags2a bits (no room for
// a P3_ON_OBJECT flag), so we check from P3's side only.


//-------------------------------------------------------//
// Core P3 collision check                               //
//-------------------------------------------------------//

function void P3.PlatformCheck()
{
	u32 p3 = P3_ADDR
	if (u32[p3] == 0)
		return
	if ((u8[p3 + 0x04] & render_flag.VISIBLE) == 0)
		return
	if (u8[p3 + 0x05] >= base_state.DIED)
		return

	// If P3 is already riding this object, check continued contact
	if ((u8[p3 + 0x2a] & char.flag.ON_OBJECT) && u16[p3 + 0x42] == (A0 & 0xffff))
	{
		u16 fullWidth = D1.u16 * 2
		s16 dx = s16(u16[p3 + 0x10]) - s16(objA0.position.x.u16) + s16(D1.u16)

		if (dx >= 0 && u16(dx) < fullWidth && (u8[p3 + 0x2a] & char.flag.IN_AIR) == 0)
		{
			// Still on platform — carry P3 with platform movement
			u32 backupA1 = A1
			A1 = p3
			u32 backupD2 = D2
			D2.u16 = D4.u16
			UpdateSonicPositionOnMovingObject()
			D2 = backupD2
			A1 = backupA1
			D4 = 0
			return
		}

		// P3 walked off or jumped — release
		u8[p3 + 0x2a] &= ~char.flag.ON_OBJECT
		u8[p3 + 0x2a] |= char.flag.IN_AIR
		u16[p3 + 0x42] = 0
		return
	}

	// New collision check — same math as fn01dcb6_internal
	s16 dx = s16(u16[p3 + 0x10]) - s16(objA0.position.x.u16)
	s16 dy = s16(u16[p3 + 0x14]) - s16(objA0.position.y.u16)

	if (abs(dx) >= s16(D1.u16) || abs(dy) >= s16(D2.u16))
		return

	if (dy < 0 && s16[p3 + 0x1a] >= 0)
	{
		// Approaching from above — land on platform
		u16[p3 + 0x14] = objA0.position.y.u16 - D3.u16
		s16[p3 + 0x1a] = 0
		u8[p3 + 0x2a] &= ~char.flag.IN_AIR
		u8[p3 + 0x2a] |= char.flag.ON_OBJECT
		u16[p3 + 0x42] = A0 & 0xffff
	}
	else if (abs(dx) > abs(dy))
	{
		// Side collision — push horizontally
		if (dx > 0)
			u16[p3 + 0x10] = objA0.position.x.u16 + u16(D1.u16)
		else
			u16[p3 + 0x10] = objA0.position.x.u16 - u16(D1.u16)
		s16[p3 + 0x18] = 0
		s16[p3 + 0x1c] = 0
	}
}


//-------------------------------------------------------//
// P3 platform release check                             //
//-------------------------------------------------------//
// Called each frame from BaseUpdate.Knuckles3 to handle
// the case where the platform P3 was standing on got
// unloaded or moved away without running its collision.

function void P3.CheckPlatformRelease()
{
	u32 p3 = P3_ADDR
	if ((u8[p3 + 0x2a] & char.flag.ON_OBJECT) == 0)
		return

	u16 objSlot = u16[p3 + 0x42]
	if (objSlot == 0)
	{
		u8[p3 + 0x2a] &= ~char.flag.ON_OBJECT
		u8[p3 + 0x2a] |= char.flag.IN_AIR
		return
	}

	// Check if the object is still alive
	u32 objAddr = 0xffff0000 + objSlot
	if (u32[objAddr] == 0)
	{
		u8[p3 + 0x2a] &= ~char.flag.ON_OBJECT
		u8[p3 + 0x2a] |= char.flag.IN_AIR
		u16[p3 + 0x42] = 0
	}
}


//-------------------------------------------------------//
// Platform collision overrides (with register protection)
//-------------------------------------------------------//

//# address-hook(0x01dc56)
function void fn01dc56()
{
	u32 savedD1 = D1
	u32 savedD2 = D2
	u32 savedD3 = D3
	u32 savedD4 = D4

	base.fn01dc56()

	if (useSonicTailsAndKnuckles)
	{
		D1 = savedD1
		D2 = savedD2
		D3 = savedD3
		D4 = savedD4
		P3.PlatformCheck()
	}
}

