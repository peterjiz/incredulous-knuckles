//-------------------------------------------------------//
// Springs overrides                                     //
//-------------------------------------------------------//
// Springs: save/restore registers, then check P3 bounce
// with the correct collision box parameters.

//# address-hook(0x022ef4)
function void SpringVertical.Update()
{
	u32 savedD1 = D1
	u32 savedD2 = D2

	base.SpringVertical.Update()

	if (useSonicTailsAndKnuckles)
	{
		D1 = savedD1
		D2 = savedD2
		P3.CheckSpringBounce(false, false)
	}
}

//# address-hook(0x023326)
function void SpringVerticalFlipped.Update()
{
	u32 savedD1 = D1
	u32 savedD2 = D2

	base.SpringVerticalFlipped.Update()

	if (useSonicTailsAndKnuckles)
	{
		D1 = savedD1
		D2 = savedD2
		P3.CheckSpringBounce(true, false)
	}
}

//# address-hook(0x023050)
function void SpringHorizontal.Update()
